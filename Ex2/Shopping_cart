# Shopping cart

item = input("Print the item you want to buy: ")

while True:

    try:
        price = float(input("Price: "))
        if price <=0:
            raise ValueError
        break
    except ValueError:
        print("You can only enter positive numbers.")

while True:
        try:
            quantity = int(input("And quantity: "))
            if quantity <=0:
                raise ValueError
            break
        except ValueError:
            print("You can have only positive WHOLE numbers")

value = price * quantity
print(f"You have selected {quantity} {item}.\nThe final price is {value}$")
